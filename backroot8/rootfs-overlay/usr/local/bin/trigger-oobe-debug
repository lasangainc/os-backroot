#!/bin/bash
# Arm first-run OOBE on a live ISO/USB session (developer debug).
set -euo pipefail

if [[ "$(id -u)" -ne 0 ]]; then
    exec sudo --preserve-env=DISPLAY "${BASH_SOURCE[0]}" "$@"
fi

if ! /usr/lib/backroot8/is-live-boot.sh; then
    echo "trigger-oobe-debug: only for live boot (backroot8iso on cmdline)" >&2
    exit 1
fi

mkdir -p /etc/backroot8 /run/br8-oobe
chmod 1777 /run/br8-oobe 2>/dev/null || true

rm -f /etc/backroot8/oobe-complete /etc/backroot8/desktop-user
touch /etc/backroot8/oobe-debug /etc/backroot8/oobe-pending

rm -f /run/br8-oobe/keep-loading /run/br8-oobe/panel-ready \
    /run/br8-oobe/loading-status /run/br8-oobe/pass /run/br8-oobe/wallpaper

echo "OOBE debug armed. Restarting desktop..."
systemd-run --no-block --collect \
    /usr/bin/systemctl restart backroot8-desktop.service
