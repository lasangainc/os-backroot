#!/bin/sh
# Backroot 8 session startup
export DESKTOP_SESSION=backroot8
export DISPLAY=:0
xrdb -merge /etc/X11/Xresources 2>/dev/null || true

SPLASH=/usr/share/backroot8/bootscreen.png
WALLPAPER=/usr/share/backgrounds/backroot8.jpg

# Loading splash on black until panel and wallpaper are up
xsetroot -solid black
if command -v feh >/dev/null && [ -r "$SPLASH" ]; then
    feh --fullscreen --scale-down --auto-zoom --image-bg black --borderless "$SPLASH" &
    SPLASH_PID=$!
fi

if command -v feh >/dev/null && [ -r "$WALLPAPER" ]; then
    feh --bg-fill "$WALLPAPER" &
else
    xsetroot -solid "#1e2030"
fi

# Panel (launcher captures crashes for WM error UI)
/usr/share/backroot8/br8-panel-launcher.sh &
PANEL_PID=$!

# Start menu overlay (Home / Apps launcher)
( while true; do /usr/local/bin/br8-start; sleep 1; done ) &

# Live USB/ISO: install wizard (metro window)
if /usr/lib/backroot8/is-live-boot.sh; then
    /usr/local/bin/br8-install &
fi

# First boot after install: OOBE (fullscreen metro)
if [ -f /etc/backroot8/oobe-pending ] && ! /usr/lib/backroot8/is-live-boot.sh; then
    /usr/local/bin/br8-oobe &
fi

# Default terminal (skip during live install wizard or OOBE)
if ! /usr/lib/backroot8/is-live-boot.sh && [ ! -f /etc/backroot8/oobe-pending ]; then
    xterm -fa Monospace -fs 11 -bg "#1a1a22" -fg "#e8e8ec" \
        -title "${USER:-root}@Backroot8" -e /bin/bash -l &
fi

if [ -n "${SPLASH_PID:-}" ]; then
    sleep 1
    kill "$SPLASH_PID" 2>/dev/null || true
fi

# Window manager (exec keeps the X session alive)
# Export X desktop over VNC for noVNC (QEMU std VGA shows the text console)
if command -v x11vnc >/dev/null; then
    x11vnc -display :0 -forever -nopw -listen 127.0.0.1 -rfbport 5900 -shared -bg -o /tmp/x11vnc.log
fi
exec /usr/local/bin/br8-wm
