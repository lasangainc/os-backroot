<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">
  <menu id="root-menu" label="Backroot 8">
    <item label="New terminal">
      <action name="Execute">
        <command>xterm -fa Monospace -fs 11 -bg "#1a1a22" -fg "#e8e8ec" -title "Backroot8" -e /bin/bash -l</command>
      </action>
    </item>
    <item label="File manager">
      <action name="Execute">
        <command>pcmanfm</command>
      </action>
    </item>
    <separator />
    <item label="Reconfigure">
      <action name="Reconfigure" />
    </item>
    <item label="Restart Openbox">
      <action name="Restart" />
    </item>
  </menu>
  <menu id="client-menu" label="Window">
    <item label="Minimize">
      <action name="Iconify" />
    </item>
    <item label="Maximize">
      <action name="ToggleMaximize" />
    </item>
    <separator />
    <item label="Close">
      <action name="Close" />
    </item>
  </menu>
</openbox_menu>
