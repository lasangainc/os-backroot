[Unit]
Description=Backroot 8 Desktop (X11)
After=network.target backroot8-splash.service

[Service]
User=root
TTYPath=/dev/tty1
TTYVTDisallocate=yes
Pty=yes
StandardInput=tty
StandardOutput=journal
StandardError=journal
Environment=HOME=/root
ExecStartPre=-/usr/bin/killall -q fbi
ExecStart=/usr/bin/startx
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
