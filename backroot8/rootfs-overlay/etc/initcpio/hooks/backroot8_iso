#!/usr/bin/ash
# Backroot 8 ISO: load squashfs from media; ext4-in-squashfs uses RAM copy.

run_hook() {
    . /usr/lib/initcpio/br8_boot_util

    if ! grep -q 'backroot8iso' /proc/cmdline; then
        return 0
    fi

    modprobe isofs 2>/dev/null
    modprobe squashfs 2>/dev/null
    modprobe loop 2>/dev/null

    mnt=/run/backroot8iso
    sqmnt=/run/br8/sq
    mkdir -p "$mnt" "$sqmnt"

    iso_dev=
    for candidate in /dev/disk/by-label/BACKROOT8_M1 /dev/sr0 /dev/sr1; do
        if [ ! -e "$candidate" ]; then
            continue
        fi
        if mount -t iso9660 -o ro "$candidate" "$mnt" 2>/dev/null; then
            if [ -f "$mnt/backroot8-root.squashfs" ]; then
                iso_dev=$candidate
                break
            fi
            umount "$mnt" 2>/dev/null
        fi
    done

    if [ -z "$iso_dev" ]; then
        echo "backroot8_iso: could not mount Backroot 8 ISO" >/dev/console
        return 1
    fi

    if ! mount -t squashfs -o ro "$mnt/backroot8-root.squashfs" "$sqmnt"; then
        echo "backroot8_iso: squashfs mount failed" >/dev/console
        return 1
    fi
    umount "$mnt"

    # Squashfs holds the rootfs tree — backroot8_root hook mounts overlay.
    if [ -f "$sqmnt/bin/bash" ]; then
        br8_log "squashfs rootfs loaded"
        return 0
    fi

    if [ ! -f "$sqmnt/backroot8-root.img" ]; then
        echo "backroot8_iso: invalid ISO layout" >/dev/console
        return 1
    fi

    imgsz=$(stat -c %s "$sqmnt/backroot8-root.img" 2>/dev/null || echo 0)
    br8_log "copying root ($((imgsz / 1024 / 1024)) MiB) to RAM..."
    if ! cp "$sqmnt/backroot8-root.img" /run/backroot8-root.img; then
        echo "backroot8_iso: RAM copy failed — use 4GB+ RAM or rebuild ISO with squashfs root" >/dev/console
        return 1
    fi
    umount "$sqmnt"

    img_dev=$(losetup -f)
    if [ -z "$img_dev" ]; then
        echo "backroot8_iso: no free loop device" >/dev/console
        return 1
    fi
    if ! losetup "$img_dev" /run/backroot8-root.img; then
        echo "backroot8_iso: losetup failed" >/dev/console
        return 1
    fi
    br8_log "writable root on ${img_dev}"
}
