#!/usr/bin/ash
# Paint boot emblem on /dev/fb0 early (Plymouth DRM often blank on QEMU -vga std).

br8_fb_splash() {
    grep -q 'br8\.debug' /proc/cmdline && return 0
    grep -q 'plymouth\.enable=0' /proc/cmdline && return 0
    [ -x /usr/bin/fbi ] || return 0
    [ -r /usr/share/backroot8/bootscreen.png ] || return 0

    modprobe bochs_drm 2>/dev/null
    modprobe simpledrm 2>/dev/null
    sleep 0.2

    if [ ! -c /dev/fb0 ]; then
        return 0
    fi

    fbi -T 1 -d /dev/fb0 -noverbose -fit /usr/share/backroot8/bootscreen.png </dev/null 2>/dev/null &
}

run_hook() {
    . /usr/lib/initcpio/br8_boot_util
    grep -q 'backroot8iso' /proc/cmdline || return 0
    br8_fb_splash
}
