#!/usr/bin/ash
# Paint boot emblem on /dev/fb0 before the Plymouth hook (see mkinitcpio HOOKS order).

br8_fb_splash() {
    grep -q 'br8\.debug' /proc/cmdline && return 0
    grep -q 'plymouth\.enable=0' /proc/cmdline && return 0
    [ -x /usr/bin/fbi ] || return 0

    _img=$(br8_pick_bootscreen) || return 0

    modprobe bochs 2>/dev/null
    sleep 0.2

    if [ ! -c /dev/fb0 ]; then
        return 0
    fi

    br8_fbi_show "$_img" 1
}

run_hook() {
    . /usr/lib/initcpio/br8_boot_util
    grep -q 'backroot8iso' /proc/cmdline || return 0
    br8_fb_splash
}
